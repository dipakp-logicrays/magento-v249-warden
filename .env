WARDEN_ENV_NAME=mage249
WARDEN_ENV_TYPE=magento2
WARDEN_WEB_ROOT=/

TRAEFIK_DOMAIN=mage249.test
TRAEFIK_SUBDOMAIN=app

WARDEN_DB=1
WARDEN_ELASTICSEARCH=0
WARDEN_OPENSEARCH=1
WARDEN_ELASTICHQ=0
WARDEN_VARNISH=0
WARDEN_RABBITMQ=1
WARDEN_REDIS=1
WARDEN_PHP_SPX=0

# Magento 2.4.9 system requirements (per Adobe):
#   PHP 8.5, Composer 2.9.3+, OpenSearch 3, RabbitMQ 4.2,
#   MariaDB 11.8/12.3 (MySQL 8.0 also accepted by Warden), Valkey 9 (Redis 7.2 used here), nginx 1.28.
# ELASTICSEARCH_VERSION=7.16
OPENSEARCH_VERSION=3.3
MYSQL_DISTRIBUTION=mysql
MYSQL_DISTRIBUTION_VERSION=8.0
NODE_VERSION=20
COMPOSER_VERSION=2.9
PHP_VERSION=8.5
PHP_XDEBUG_3=0
RABBITMQ_VERSION=4.2
REDIS_VERSION=7.2
VARNISH_VERSION=7.7

WARDEN_SYNC_IGNORE=

# Database Persistence Configuration
# Store database files on host machine instead of Docker volume
# This ensures database persists even if Docker volumes are deleted
DB_DATA_PATH=./dbdata

# Mailpit Persistence Configuration
# Store mailpit emails on host machine instead of Docker volume
# This ensures emails persist even if Docker containers are restarted
MAILPIT_DATA_PATH=./mailpitdata

WARDEN_ALLURE=0
WARDEN_SELENIUM=0
WARDEN_SELENIUM_DEBUG=0
WARDEN_BLACKFIRE=0
WARDEN_SPLIT_SALES=0
WARDEN_SPLIT_CHECKOUT=0
WARDEN_TEST_DB=0
WARDEN_MAGEPACK=0

MAGEPACK_VERSION=2.11

WARDEN_MAGENTO2_GRAPHQL_SERVER=0
WARDEN_MAGENTO2_GRAPHQL_SERVER_DEBUG=0

BLACKFIRE_CLIENT_ID=
BLACKFIRE_CLIENT_TOKEN=
BLACKFIRE_SERVER_ID=
BLACKFIRE_SERVER_TOKEN=
WARDEN_SERVICE_DOMAIN=mage249.test

# Status dashboard label — shown in the header dropdown. Defaults to WARDEN_ENV_NAME.
# It should be your site title
STATUS_DASHBOARD_LABEL=Magento 2.4.9 Luma Demo
